<?xml version="1.0" encoding="utf-8"?>
<!--colors.xml dla motywu jasnego– definicje kolorów używanych w aplikacji (motyw, wykresy, tła itp.).-->

<resources>
    <!--Ogólne kolory-->
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>

    <!--Fioletowe przyciski-->
    <color name="buttonBackground">#7F61E0</color>
    <color name="buttonText">#FFFFFFFF</color>

    <!--Niebieskie przyciski-->
    <color name="buttonPrimaryBackground">#1976D2</color>
    <color name="buttonPrimaryText">#FFFFFFFF</color>

    <!-- Czerwone przyciski (RESET, USUŃ) -->
    <color name="buttonDangerBackground">#D32F2F</color>
    <color name="buttonDangerText">#FFFFFF</color>

    <!--Kolor status opłacony i nieopłacony-->
    <color name="statusPaid">#5CB85C</color>
    <color name="statusUnpaid">#D9534F</color>

    <!--Dialog categorii i osób w SettingsActivity-->
    <color name="dialogBackground">#FFFFFF</color>
    <color name="dialogText">#000000</color>
    <color name="dialogHint">#757575</color>
    <color name="dialogStroke">#B0B0B0</color>

    <!--Kolory separatora-->
    <color name="dividerLight">#33000000</color>  <!-- czarny 20% -->
    <color name="dividerDark">#33FFFFFF</color>   <!-- biały 20% -->
</resources>