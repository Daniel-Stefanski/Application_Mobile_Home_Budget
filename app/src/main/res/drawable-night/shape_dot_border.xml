<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!--dot_border.xml (night)– narzędzia do tworzenia obramowania dla kolorów kategorii w legendzie. Wersja dla motywu ciemnego.-->

    <!-- W ciemnym trybie lekko ciemniejsze tło -->
    <solid android:color="#2C2C2C"/>

    <!-- Jasne obramowanie -->
    <stroke android:width="1dp" android:color="#FFFFFF"/>

    <!-- Zaokrąglenie rogów, żeby nie były ostre -->
    <corners android:radius="4dp"/>
</shape>