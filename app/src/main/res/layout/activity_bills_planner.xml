<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!--activity_bills_planner.xml - uklad planera rachunkow.-->
    <TextView
        android:id="@+id/titleBills"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Planer rachunkow"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="?android:textColorPrimary"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        android:padding="8dp" />

    <Button
        android:id="@+id/buttonBackToMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Powrot do ekranu glownego"
        android:textColor="@color/buttonText"
        android:backgroundTint="@color/buttonBackground"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/buttonAddBill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Dodaj rachunek"
        android:textColor="@color/buttonText"
        android:backgroundTint="@color/buttonBackground" />

    <include
        android:id="@+id/includeBillsSummary"
        layout="@layout/item_bills_summary" />

    <TextView
        android:id="@+id/textEmptyPlanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Brak rachunkow w planerze.&#10;Kliknij dodaj rachunek, aby utworzyc pierwszy wpis."
        android:textSize="18sp"
        android:textColor="?android:textColorPrimary"
        android:gravity="center"
        android:padding="24dp"
        android:visibility="gone"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerBills"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:contentDescription="Lista rachunkow" />

</LinearLayout>
