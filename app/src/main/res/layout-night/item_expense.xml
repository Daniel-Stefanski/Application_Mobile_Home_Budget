<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    card_view:cardCornerRadius="14dp"
    card_view:cardElevation="4dp"
    card_view:cardUseCompatPadding="true"
    android:backgroundTint="#2C2C2C">
    <!--item_expense.xml (night)– pojedynczy element listy wydatków w historii. Wersja dla ciemnego motywu.-->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">
        <!--Nagłówek: Kategoria i Kwota-->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/textCategory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kategoria:"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#EAEAEA"/>
            <TextView
                android:id="@+id/textAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kwota:"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="#EAEAEA"/>
        </LinearLayout>
        <!--Opis-->
        <TextView
            android:id="@+id/textDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opis:"
            android:textSize="14sp"
            android:layout_marginTop="6dp"
            android:textColor="#EAEAEA"/>
        <!--Notatka-->
        <TextView
            android:id="@+id/textNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notatka:"
            android:visibility="gone"
            android:textColor="#EAEAEA"/>
        <!--Metoda płatności-->
        <TextView
            android:id="@+id/textPayment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Metoda płatności:"
            android:textColor="#EAEAEA"/>
        <!--Czyj wydatek-->
        <TextView
            android:id="@+id/textPerson"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Osoba:"
            android:textColor="#EAEAEA"/>
        <!--Data-->
        <TextView
            android:id="@+id/textDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Data:"
            android:textColor="#EAEAEA"/>
        <!--Powtarzalny wydatek-->
        <TextView
            android:id="@+id/textRecurring"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Powtarzalny wydatek:"
            android:textStyle="italic"
            android:textColor="#A694F9"
            android:visibility="gone"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>