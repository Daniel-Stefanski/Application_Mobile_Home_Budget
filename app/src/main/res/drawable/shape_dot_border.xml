<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!--dot_border.xml – narzędzia do tworzenia obramowania dla kolorów kategorii w legendzie.-->

    <!-- Domyślne tło, które i tak nadpiszemy w kodzie kolorem kategorii -->
    <solid android:color="#FFFFFF"/>

    <!-- Obramowanie widoczne w jasnym motywie -->
    <stroke android:width="1dp" android:color="#000000"/>

    <!-- Zaokrąglenie rogów, żeby nie były ostre -->
    <corners android:radius="4dp"/>
</shape>