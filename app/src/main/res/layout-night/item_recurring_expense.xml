<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="13dp"
    app:cardElevation="4dp"
    app:strokeWidth="1dp"
    app:strokeColor="#A694F9"
    android:backgroundTint="#2C2C2C">

    <!--item_recurring_expense.xml – pojedynczy element listy wydatków cyklicznych.-->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!--Kolorowy pasek statusy-->
        <View
            android:id="@+id/statusBar"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="#CCCCCC"/>

        <!-- TWOJE DOTYCHCZASOWE WNĘTRZE KARTY -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">
            <TextView
                android:id="@+id/textBillDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opis: "
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#C8BFFF"/>

            <TextView
                android:id="@+id/textBillAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kwota: "
                android:textSize="14sp"
                android:textColor="#EAEAEA"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/textBillNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notatka: brak"
                android:textStyle="italic"
                android:textColor="#EAEAEA"
                android:paddingTop="4dp"/>

            <TextView
                android:id="@+id/textBillDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data: 01.01.2025"
                android:textSize="14sp"
                android:textColor="#EAEAEA"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/textBillRecurring"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powtarza się co miesiąc"
                android:textSize="14sp"
                android:textColor="#EAEAEA"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/textBillStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: nieopłacony"
                android:textSize="14sp"
                android:textColor="#EAEAEA"
                android:layout_marginTop="4dp"/>

            <!--Sekcja Przyciksi-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:layout_marginTop="8dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="4dp">
                    <!--Przycisk usuwający rachunek i odznaczający checkboxa-->
                    <Button
                        android:id="@+id/buttonDeleteBill"
                        android:layout_width="120dp"
                        android:layout_height="48dp"
                        android:text="🗑️ Usuń"
                        android:textSize="14sp"
                        android:textColor="@color/buttonText"
                        android:backgroundTint="@color/buttonBackground"
                        android:layout_marginStart="6dp"/>
                    <!--Przycisk edytujący rachunek-->
                    <Button
                        android:id="@+id/buttonEditBill"
                        android:layout_width="120dp"
                        android:layout_height="48dp"
                        android:text="✏️ Edytuj"
                        android:textSize="14sp"
                        android:textColor="@color/buttonText"
                        android:backgroundTint="@color/buttonBackground"
                        android:layout_marginEnd="6dp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">
                    <!--Przycisk oznaczania opłacony-->
                    <Button
                        android:id="@+id/buttonMarkPaid"
                        android:layout_width="130dp"
                        android:layout_height="48dp"
                        android:text="✔ Opłacony"
                        android:textSize="14sp"
                        android:textColor="@color/buttonText"
                        android:backgroundTint="@color/buttonBackground"
                        android:layout_marginEnd="6dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>